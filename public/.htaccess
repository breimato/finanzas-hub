DirectoryIndex index.php index.html

<IfModule mod_headers.c>
  Header set X-Accel-Expires "0"
  Header set X-Cache-Enabled "False"
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
  <FilesMatch "\.(js|css|svg|png|jpg|webp|woff2?|ico|txt|xml)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /finanzas/
  RewriteRule ^$ index.php [L]
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} !\.(js|css|svg|png|jpg|webp|woff2?|ico|txt|xml)$ [NC]
  RewriteRule . index.html [L]
</IfModule>
